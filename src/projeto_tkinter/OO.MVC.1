import tkinter as tk
from tkinter import colorchooser

# Model: --> APENAS OS DADOS DA APLICAÇÃO

class Modelo:
    def __init__(self):
        self.forma="pincel"
        self.cor_borda="black"
        self.cor_preenchimento="black"
        self.tamanho=2
        self.inicio_x=0
        self.inicio_y=0
        self.ultimo_x=None
        self.ultimo_y=None
        self.objeto=None
        self.pontos_poligono=[]
        self.linhas_guia=[]

# View: --> INTERFACE

class Visao:
    def __init__(self,janela):
        self.janela=janela
        janela.title("Paint - MVC")
        janela.geometry("1000x1000")
        janela.grid_columnconfigure(0,weight=1)
        janela.grid_rowconfigure(0,weight=1)

        self.barra_vertical=tk.Scrollbar(janela,orient=tk.VERTICAL)
        self.barra_horizontal=tk.Scrollbar(janela,orient=tk.HORIZONTAL)

        self.tela=tk.Canvas(janela,bg="white",scrollregion=(0,0,1000,1000),
                            yscrollcommand=self.barra_vertical.set,
                            xscrollcommand=self.barra_horizontal.set)

        self.barra_vertical.config(command=self.tela.yview)
        self.barra_horizontal.config(command=self.tela.xview)

        self.tela.grid(row=0,column=0,sticky="nsew")
        self.barra_vertical.grid(row=0,column=1,sticky="ns")
        self.barra_horizontal.grid(row=1,column=0,sticky="ew")

        self.quadro=tk.Frame(janela)  # cria um quadro para os botões e controles 
        self.quadro.grid(row=2,column=0,sticky="ew")

        def botao(txt):  # cria um botão com o texto txt e o adiciona ao quadro
            botao=tk.Button(self.quadro,text=txt)
            botao.pack(side=tk.LEFT)
            return botao

        # cria respectivos botões para cada forma geométrica (usando a função 'b'):
        self.botao_pincel=botao("Pincel")
        self.botao_linha=botao("Linha")
        self.botao_retangulo=botao("Retângulo")
        self.botao_oval=botao("Oval")
        self.botao_circulo=botao("Círculo")
        self.botao_poligono=botao("Polígono")

        tk.Label(self.quadro,text="Tamanho").pack(side=tk.LEFT)
        self.escala_tamanho=tk.Scale(self.quadro,from_=1,to=20,orient=tk.HORIZONTAL)  # cria uma escala para o tamanho do pincel
        self.escala_tamanho.set(2)
        self.escala_tamanho.pack(side=tk.LEFT)

        self.botao_cor_borda=botao("Cor Borda")
        self.botao_cor_preenchimento=botao("Cor Preenchimento")

class Controlador:
    def __init__(self,modelo,visao):  # liga o modelo à visão e define os eventos de interação do usuário
        self.modelo=modelo
        self.visao=visao

        visao.botao_pincel.config(command=lambda:self.forma("pincel"))
        visao.botao_linha.config(command=lambda:self.forma("linha"))
        visao.botao_retangulo.config(command=lambda:self.forma("retangulo"))
        visao.botao_oval.config(command=lambda:self.forma("oval"))
        visao.botao_circulo.config(command=lambda:self.forma("circulo"))
        visao.botao_poligono.config(command=lambda:self.forma("poligono"))

        visao.botao_cor_borda.config(command=self.cor_borda)
        visao.botao_cor_preenchimento.config(command=self.cor_preenchimento)

        visao.escala_tamanho.config(command=lambda x:setattr(self.modelo,"tamanho",int(x)))

        visao.tela.bind("<Button-1>",self.clicar)
        visao.tela.bind("<B1-Motion>",self.arrastar)
        visao.tela.bind("<ButtonRelease-1>",lambda e:setattr(self.modelo,"objeto",None))
        visao.tela.bind("<Double-Button-1>",self.fechar)

    def forma(self,f):
        self.modelo.forma=f

    def cor_borda(self):
        c=colorchooser.askcolor()[1]
        if c:self.modelo.cor_borda=c

    def cor_preenchimento(self):
        c=colorchooser.askcolor()[1]
        if c:self.modelo.cor_preenchimento=c

    def clicar(self,e):
        x=self.visao.tela.canvasx(e.x)
        y=self.visao.tela.canvasy(e.y)

        if self.modelo.forma=="poligono":
            self.modelo.pontos_poligono.extend([x,y])
            if len(self.modelo.pontos_poligono)>=4:
                x1,y1=self.modelo.pontos_poligono[-4],self.modelo.pontos_poligono[-3]
                l=self.visao.tela.create_line(x1,y1,x,y,fill=self.modelo.cor_borda,width=self.modelo.tamanho)
                self.modelo.linhas_guia.append(l)
            return

        self.modelo.inicio_x=x
        self.modelo.inicio_y=y
        self.modelo.ultimo_x=x
        self.modelo.ultimo_y=y

    def arrastar(self,e):
        if self.modelo.forma=="poligono": 
            return
        x=self.visao.tela.canvasx(e.x)
        y=self.visao.tela.canvasy(e.y)

        if self.modelo.forma=="pincel":
            self.visao.tela.create_line(self.modelo.ultimo_x,self.modelo.ultimo_y,x,y,
                                        fill=self.modelo.cor_borda,
                                        width=self.modelo.tamanho,
                                        smooth=True)
            self.modelo.ultimo_x=x
            self.modelo.ultimo_y=y
        else:
            if self.modelo.forma=="circulo":
                lado=min(abs(x-self.modelo.inicio_x),abs(y-self.modelo.inicio_y))
                x=self.modelo.inicio_x+lado if x>=self.modelo.inicio_x else self.modelo.inicio_x-lado
                y=self.modelo.inicio_y+lado if y>=self.modelo.inicio_y else self.modelo.inicio_y-lado

            if self.modelo.objeto:
                self.visao.tela.coords(self.modelo.objeto,self.modelo.inicio_x,self.modelo.inicio_y,x,y)
            else:
                if self.modelo.forma=="linha":
                    self.modelo.objeto=self.visao.tela.create_line(self.modelo.inicio_x,self.modelo.inicio_y,x,y,
                                                                   fill=self.modelo.cor_borda,
                                                                   width=self.modelo.tamanho)
                elif self.modelo.forma=="retangulo":
                    self.modelo.objeto=self.visao.tela.create_rectangle(self.modelo.inicio_x,self.modelo.inicio_y,x,y,
                                                                        outline=self.modelo.cor_borda,
                                                                        fill=self.modelo.cor_preenchimento)
                else:
                    self.modelo.objeto=self.visao.tela.create_oval(self.modelo.inicio_x,self.modelo.inicio_y,x,y,
                                                                   outline=self.modelo.cor_borda,
                                                                   fill=self.modelo.cor_preenchimento)

    def fechar(self,e):
        if self.modelo.forma=="poligono" and len(self.modelo.pontos_poligono)>=6:
            for l in self.modelo.linhas_guia:
                self.visao.tela.delete(l)
            self.modelo.linhas_guia.clear()
            self.visao.tela.create_polygon(self.modelo.pontos_poligono,
                                           outline=self.modelo.cor_borda,
                                           fill=self.modelo.cor_preenchimento,
                                           width=self.modelo.tamanho)
            self.modelo.pontos_poligono.clear()

if __name__=="__main__":
    janela=tk.Tk()
    modelo=Modelo()
    visao=Visao(janela)
    Controlador(modelo,visao)
    janela.mainloop()
